{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Aegis Policy Language",
  "scopeName": "source.aegis",
  "fileTypes": ["aegis"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#policy-declaration" },
    { "include": "#proof-declaration" },
    { "include": "#invariant-declaration" },
    { "include": "#type-declaration" },
    { "include": "#function-declaration" },
    { "include": "#temporal-keywords" },
    { "include": "#verdict-keywords" },
    { "include": "#quantifier-keywords" },
    { "include": "#action-keywords" },
    { "include": "#control-keywords" },
    { "include": "#declaration-keywords" },
    { "include": "#type-keywords" },
    { "include": "#severity-levels" },
    { "include": "#boolean-keywords" },
    { "include": "#logical-operators" },
    { "include": "#context-event" },
    { "include": "#duration-literals" },
    { "include": "#numeric-literals" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.aegis",
          "match": "//.*$"
        },
        {
          "name": "comment.block.aegis",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.aegis" }
          }
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "comment": "Raw string r\"...\": no escape processing",
          "name": "string.quoted.double.raw.aegis",
          "begin": "r\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.aegis" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.aegis" }
          }
        },
        {
          "comment": "Regular double-quoted string with escape sequences",
          "name": "string.quoted.double.aegis",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.aegis" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.aegis" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.aegis",
              "match": "\\\\."
            }
          ]
        },
        {
          "comment": "Regex literal /pattern/flags",
          "name": "string.regexp.aegis",
          "match": "/(?:[^/\\\\\\r\\n]|\\\\.)+/[a-z]*",
          "captures": {
            "0": { "name": "string.regexp.aegis" }
          }
        }
      ]
    },

    "annotations": {
      "comment": "@author(...), @version(...), @environment(...)",
      "name": "meta.annotation.aegis",
      "begin": "@(\\w+)",
      "end": "(?<=\\))|(?![( ])",
      "beginCaptures": {
        "0": { "name": "entity.name.tag.annotation.aegis" },
        "1": { "name": "entity.name.tag.annotation.aegis" }
      },
      "patterns": [
        {
          "begin": "\\(",
          "end": "\\)",
          "beginCaptures": { "0": { "name": "punctuation.section.arguments.begin.aegis" } },
          "endCaptures": { "0": { "name": "punctuation.section.arguments.end.aegis" } },
          "patterns": [
            { "include": "#strings" },
            { "include": "#numeric-literals" },
            { "include": "#boolean-keywords" }
          ]
        }
      ]
    },

    "policy-declaration": {
      "comment": "Captures: policy MyPolicyName [extends QualifiedName]",
      "match": "\\b(policy)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+(extends)\\s+([A-Za-z_][A-Za-z0-9_.]*))?",
      "captures": {
        "1": { "name": "keyword.control.policy.aegis" },
        "2": { "name": "entity.name.type.policy.aegis" },
        "3": { "name": "keyword.declaration.extends.aegis" },
        "4": { "name": "entity.name.type.policy.aegis" }
      }
    },

    "proof-declaration": {
      "comment": "Captures: proof ProofName",
      "match": "\\b(proof)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.proof.aegis" },
        "2": { "name": "entity.name.type.proof.aegis" }
      }
    },

    "invariant-declaration": {
      "comment": "Captures: invariant InvariantName",
      "match": "\\b(invariant)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.invariant.aegis" },
        "2": { "name": "entity.name.type.invariant.aegis" }
      }
    },

    "type-declaration": {
      "comment": "Captures: type TypeName",
      "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.type.aegis" },
        "2": { "name": "entity.name.type.aegis" }
      }
    },

    "function-declaration": {
      "comment": "Captures: def functionName",
      "match": "\\b(def)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.def.aegis" },
        "2": { "name": "entity.name.function.aegis" }
      }
    },

    "temporal-keywords": {
      "comment": "LTL temporal operators — the formal verification core",
      "name": "keyword.operator.temporal.aegis",
      "match": "\\b(always|eventually|never|until|before|after|next|within|during)\\b"
    },

    "verdict-keywords": {
      "comment": "Rule verdicts: outcomes of policy evaluation",
      "name": "keyword.operator.verdict.aegis",
      "match": "\\b(allow|deny|audit|redact)\\b"
    },

    "quantifier-keywords": {
      "comment": "Collection quantifiers and count",
      "name": "keyword.operator.quantifier.aegis",
      "match": "\\b(any|all|none|exists|count)\\b"
    },

    "action-keywords": {
      "comment": "Side-effect actions and constraint declarations",
      "name": "keyword.operator.action.aegis",
      "match": "\\b(log|notify|escalate|block|tag|rate_limit|quota|severity|per)\\b"
    },

    "control-keywords": {
      "comment": "Structural control keywords",
      "name": "keyword.control.aegis",
      "match": "\\b(on|when|where|with|match|scope)\\b"
    },

    "declaration-keywords": {
      "comment": "Declaration and module keywords",
      "name": "keyword.declaration.aegis",
      "match": "\\b(import|from|as|let|extends)\\b"
    },

    "type-keywords": {
      "comment": "Built-in type names",
      "name": "support.type.primitive.aegis",
      "match": "\\b(int|float|bool|string|duration|List|Map|Set)\\b"
    },

    "severity-levels": {
      "comment": "Severity level constants",
      "name": "constant.language.severity.aegis",
      "match": "\\b(critical|high|medium|low|info)\\b"
    },

    "boolean-keywords": {
      "name": "constant.language.boolean.aegis",
      "match": "\\b(true|false)\\b"
    },

    "logical-operators": {
      "comment": "Word-form logical operators and predicates",
      "patterns": [
        {
          "name": "keyword.operator.logical.aegis",
          "match": "\\b(and|or|in|implies)\\b"
        },
        {
          "name": "keyword.operator.predicate.aegis",
          "match": "\\b(contains|matches|starts_with|ends_with)\\b"
        }
      ]
    },

    "context-event": {
      "comment": "Special built-in variables",
      "patterns": [
        {
          "name": "variable.language.context.aegis",
          "match": "\\bcontext\\b"
        },
        {
          "name": "variable.language.event.aegis",
          "match": "\\bevent\\b"
        }
      ]
    },

    "duration-literals": {
      "comment": "Duration literals must be matched before plain numbers (5ms, 10s, 300m, 1h, 7d)",
      "name": "constant.numeric.duration.aegis",
      "match": "\\b([0-9]+)(ms|s|m|h|d)\\b",
      "captures": {
        "1": { "name": "constant.numeric.duration.value.aegis" },
        "2": { "name": "constant.numeric.duration.unit.aegis" }
      }
    },

    "numeric-literals": {
      "patterns": [
        {
          "name": "constant.numeric.float.aegis",
          "match": "\\b[0-9]+\\.[0-9]+(?:[eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.aegis",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.aegis",
          "match": "==|!="
        },
        {
          "name": "keyword.operator.relational.aegis",
          "match": "<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.symbol.aegis",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.aegis",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.aegis",
          "match": "="
        },
        {
          "name": "keyword.operator.arrow.aegis",
          "match": "=>"
        },
        {
          "name": "keyword.operator.type-arrow.aegis",
          "match": "->"
        },
        {
          "name": "keyword.operator.pipe.aegis",
          "match": "\\|"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.block.begin.aegis",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.aegis",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.bracket.begin.aegis",
          "match": "\\["
        },
        {
          "name": "punctuation.section.bracket.end.aegis",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.parens.begin.aegis",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.aegis",
          "match": "\\)"
        },
        {
          "name": "punctuation.separator.comma.aegis",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.aegis",
          "match": ":"
        },
        {
          "name": "punctuation.terminator.semicolon.aegis",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.dot.aegis",
          "match": "\\."
        }
      ]
    }
  }
}
