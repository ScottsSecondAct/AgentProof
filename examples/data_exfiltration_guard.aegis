// ─────────────────────────────────────────────────────────────────
//  data_exfiltration_guard.aegis
//
//  Prevents AI agents from leaking sensitive data through tool
//  calls, external HTTP requests, or excessive data access.
// ─────────────────────────────────────────────────────────────────

import automaguard.stdlib.pii as pii
from automaguard.stdlib import network, compliance

// ─── Custom types ───────────────────────────────────────────────

type Endpoint {
    url: string,
    method: string,
    headers: Map<string, string>
}

type DataClassification {
    level: string,
    categories: List<string>,
    jurisdiction: string
}

// ─── Helper functions ───────────────────────────────────────────

// Parentheses required: `starts_with` is a postfix predicate whose
// expression argument is greedy — without parens it would consume
// the `or` and the right-hand operand as part of its own argument.
def is_internal(url: string) -> bool =
    (url starts_with "https://api.internal.") || (url starts_with "https://10.")

// ─── Primary policy ─────────────────────────────────────────────

@author("security-team")
@version("2.1.0")
policy DataExfiltrationGuard {
    severity critical
    scope tool_call, data_access, external_request

    // ── Rate limits ─────────────────────────────────────────────
    rate_limit tool_call: 100 per 1m
    rate_limit external_request: 20 per 5m
    quota data_access: 10000 per 1h

    // is_approved_destination references context, so it must live
    // inside the policy where context is in scope.
    def is_approved_destination(url: string) -> bool =
        url in context.config.approved_endpoints

    // ── Block external HTTP unless explicitly approved ──────────
    on external_request {
        when !is_approved_destination(event.endpoint.url)
        deny with "External request to unapproved destination"
        log level: "error", destination: event.endpoint.url
        notify channel: "security-alerts"
        severity critical
    }

    // ── Redact PII in outbound tool calls ───────────────────────
    on tool_call {
        when any(event.arguments, arg => pii.contains_pii(arg))
        redact with "PII detected in tool arguments"
        tag "pii-redacted"
        audit
    }

    // ── Route data_access by classification level ───────────────
    //
    // The original used let + match inside a rule body, which the
    // compiler does not support. Each branch is a separate rule.
    // event.classification follows the same convention as
    // customer_data_guard.aegis rather than calling context.classify(),
    // which returns an opaque Context type the checker cannot unpack.

    on data_access {
        when event.classification == "restricted"
        deny with "Access to restricted data requires explicit approval"
        escalate to: "data-governance"
        severity critical
    }

    on data_access {
        when event.classification == "confidential" && event.jurisdiction == "EU"
        audit with "GDPR-regulated data access"
        allow
    }

    on data_access {
        when event.classification == "internal"
        allow
    }

    // ── No bulk data extraction ─────────────────────────────────
    //
    // count() with a `within` predicate is not yet supported syntax;
    // use the runtime-maintained sliding-window counter directly.
    on data_access {
        when count(context.recent_reads) > 50
        deny with "Bulk data extraction pattern detected"
        block 30m
        notify channel: "security-alerts"
    }

    // ── Formal safety proofs ────────────────────────────────────
    proof NoDataLeaks {
        invariant InternalOnly {
            // all(context.external_requests, req => req.url ...) would require
            // the type checker to resolve the element type of the collection,
            // which it cannot do for opaque context fields. Express the same
            // property event-locally: every external_request event must target
            // an approved destination.
            always(
                event.event_type != "external_request"
                    || is_approved_destination(event.endpoint.url)
            )
        }

        invariant NoPIIExfiltration {
            after(
                !(event.tool == "send_data" && any(event.arguments, arg => pii.contains_pii(arg))),
                event.classification == "PII"
            )
        }
    }
}

// ─── Companion policy: development mode relaxation ──────────────

@environment("development")
policy DevModeRelaxed extends DataExfiltrationGuard {
    severity low

    // Allow localhost and dev endpoints
    on external_request {
        when event.endpoint.url starts_with "http://localhost"
        allow
    }

    // Wider rate limits for testing
    rate_limit tool_call: 1000 per 1m
    rate_limit external_request: 200 per 5m
}
